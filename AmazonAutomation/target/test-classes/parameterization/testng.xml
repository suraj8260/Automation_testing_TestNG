<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<!--<suite name="Suite">-->		<!-- if we write like this it will complete execution one after another-->
<suite name="Suite" parallel = "tests">		<!-- if We do like this it parallely do to in both browser at a time -->
  <test thread-count="5" name="Test1">
  	<parameter name="browser" value="chrome"/>
    <classes>
      <class name="parameterization.ParameterTest"/>
    </classes>
  </test> <!-- Test -->								<!-- Cross Browser Testing-->
    <test thread-count="5" name="Test2">
  	<parameter name="browser" value="edge"/>
    <classes>
      <class name="parameterization.ParameterTest"/>
    </classes>
  </test> <!-- Test -->

</suite> <!-- Suite -->
